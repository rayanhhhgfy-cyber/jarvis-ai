# ====================================================================
# JARVIS OMEGA — Environment Configuration
# ====================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ====================================================================

# --- API Keys ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# --- Model Configuration ---
MYTHOMAX_MODEL=gryphe/mythomax-l2-13b
QWEN_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct
WHISPER_MODEL=whisper-large-v3-turbo
KOKORO_MODEL_PATH=./models/kokoro-82m

# --- Backend Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_SECRET_KEY=change_this_to_a_strong_random_secret_key
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- WebSocket ---
WS_HEARTBEAT_INTERVAL=30
WS_RECONNECT_DELAY=5
WS_MAX_RECONNECT_ATTEMPTS=0

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./storage/chromadb
CHROMA_HOST=
CHROMA_PORT=

# --- SQLite ---
SQLITE_DB_PATH=./storage/jarvis_omega.db

# --- Security ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
DEVICE_TOKEN_EXPIRE_DAYS=365
ENCRYPTION_KEY=

# --- Push Notifications (VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=sir@jarvis-omega.local

# --- Paths ---
STORAGE_DIR=./storage
LOGS_DIR=./logs
WORKSPACE_DIR=./workspace
MEMORY_DIR=./memory
CACHE_DIR=./cache
BACKUPS_DIR=./backups

# --- Resource Limits ---
MAX_CONCURRENT_AGENTS=15
MAX_CPU_PERCENT=80
MAX_MEMORY_PERCENT=85
AGENT_TIMEOUT_SECONDS=300
MAX_RETRY_COUNT=3

# --- Wake Word ---
WAKE_WORD=jarvis
PICOVOICE_ACCESS_KEY=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
