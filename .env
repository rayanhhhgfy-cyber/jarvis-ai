# ====================================================================
# JARVIS OMEGA — Environment Configuration
# ====================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ====================================================================

# --- API Keys ---
OPENROUTER_API_KEY=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
OPENROUTER_API_KEYS=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,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,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,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,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,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,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,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,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,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,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
GROQ_API_KEY=your_groq_api_key_here

# --- Model Configuration ---
MYTHOMAX_MODEL=nvidia/nemotron-3-super-120b-a12b
QWEN_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct
WHISPER_MODEL=whisper-large-v3-turbo
KOKORO_MODEL_PATH=./models/kokoro-82m

# --- Backend Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_SECRET_KEY=change_this_to_a_strong_random_secret_key
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- WebSocket ---
WS_HEARTBEAT_INTERVAL=30
WS_RECONNECT_DELAY=5
WS_MAX_RECONNECT_ATTEMPTS=0

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./storage/chromadb
CHROMA_HOST=
CHROMA_PORT=0

# --- SQLite ---
SQLITE_DB_PATH=./storage/jarvis_omega.db

# --- Security ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
DEVICE_TOKEN_EXPIRE_DAYS=365
ENCRYPTION_KEY=

# --- Push Notifications (VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=sir@jarvis-omega.local

# --- Paths ---
STORAGE_DIR=./storage
LOGS_DIR=./logs
WORKSPACE_DIR=./workspace
MEMORY_DIR=./memory
CACHE_DIR=./cache
BACKUPS_DIR=./backups

# --- Resource Limits ---
MAX_CONCURRENT_AGENTS=15
MAX_CPU_PERCENT=80
MAX_MEMORY_PERCENT=85
AGENT_TIMEOUT_SECONDS=300
MAX_RETRY_COUNT=3

# --- Wake Word ---
WAKE_WORD=jarvis
PICOVOICE_ACCESS_KEY=

# --- GitHub Integration (Build → Push) ---
GITHUB_TOKEN=
# Personal Access Token with 'repo' scope → https://github.com/settings/tokens

# --- Vercel Integration (Build → Deploy) ---
VERCEL_TOKEN=
VERCEL_TEAM_ID=
# Get token → https://vercel.com/account/tokens

# --- Discord Bridge ---
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_ID=
DISCORD_GUILD_ID=

# --- Telegram Bridge ---
TELEGRAM_BOT_TOKEN=

# --- Vault Master Key (auto-generated if blank) ---
JARVIS_VAULT_KEY=

# --- Clerk Auth (frontend JWT verification) ---
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
